<Window x:Class="Reccoo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Reccoo"
        mc:Ignorable="d"
        Title="Reccoo"
        Width="1216" Height="820"
        MinWidth="1080" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        FontFamily="{StaticResource PixelFont}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <!-- ===== Outer window shell — pixel border + 6px offset shadow ===== -->
    <Grid Margin="6">
        <!-- Drop shadow (offset down) -->
        <Rectangle Fill="{StaticResource InkDarkBrush}" Margin="0,6,0,0"/>

        <!-- Window body -->
        <Border x:Name="WindowBody"
                BorderBrush="{StaticResource InkDarkBrush}"
                BorderThickness="3"
                Background="{StaticResource CreamBrush}"
                Margin="0,0,0,6"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ============== Title bar ============== -->
                <Border Grid.Row="0"
                        Background="{StaticResource AccentBrush}"
                        BorderBrush="{StaticResource InkDarkBrush}"
                        BorderThickness="0,0,0,3"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- top highlight stripe -->
                        <Rectangle Grid.ColumnSpan="3" Fill="#80FFFFFF" Height="2" VerticalAlignment="Top"/>
                        <!-- bottom deep stripe (inside the bar above the 3px ink border) -->
                        <Rectangle Grid.ColumnSpan="3" Fill="{StaticResource AccentDeepBrush}" Height="3" VerticalAlignment="Bottom"/>

                        <!-- left game-boy speaker dots -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                            <Border Width="10" Height="10" Background="{StaticResource InkDarkBrush}" Margin="0,0,4,0">
                                <Border Background="{StaticResource AccentSoftBrush}" Margin="2"/>
                            </Border>
                            <Border Width="10" Height="10" Background="{StaticResource InkDarkBrush}" Margin="0,0,4,0">
                                <Border Background="{StaticResource AccentSoftBrush}" Margin="2"/>
                            </Border>
                            <Border Width="10" Height="10" Background="{StaticResource InkDarkBrush}">
                                <Border Background="{StaticResource AccentSoftBrush}" Margin="2"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="♪  Reccoo — 귀여운 사운드 레코더  ♪"
                                   Foreground="{StaticResource InkDarkBrush}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Button Style="{StaticResource TitleBarButton}" Content="_" Click="Minimize_Click" Margin="0,0,6,0"/>
                            <Button Style="{StaticResource TitleBarButton}" Content="▢" Click="Maximize_Click" Margin="0,0,6,0"/>
                            <Button Style="{StaticResource TitleCloseButton}" Content="✕" Click="Close_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ============== Main body (cream + dot pattern) ============== -->
                <Grid Grid.Row="1" Background="{StaticResource CreamBrush}">
                    <Grid Margin="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="*" MinHeight="180"/>
                        </Grid.RowDefinitions>

                        <!-- ====================================================
                             MAIN STAGE — timer + waveform + transport
                             ==================================================== -->
                        <ContentControl Grid.Row="0" Grid.Column="0" Style="{StaticResource PixelPanel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- status strip -->
                                <Border Grid.Row="0"
                                        Background="{StaticResource AccentSoftBrush}"
                                        BorderBrush="{StaticResource InkDarkBrush}"
                                        BorderThickness="0,0,0,3"
                                        Padding="18,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                x:Name="StatusDot"
                                                Width="16" Height="16"
                                                Background="{StaticResource InkSoftBrush}"
                                                BorderBrush="{StaticResource InkDarkBrush}"
                                                BorderThickness="2"
                                                VerticalAlignment="Center"
                                                Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   x:Name="StatusLabel"
                                                   Text="○ 대기 중"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource InkDarkBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   x:Name="FormatInfoText"
                                                   Text="WAV · 시스템 사운드"
                                                   FontSize="12"
                                                   Foreground="{StaticResource InkSoftBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Big timer -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                                    <TextBlock x:Name="TimerMin" Text="00"
                                               FontFamily="{StaticResource PixelMonoFont}"
                                               FontWeight="Bold" FontSize="84"
                                               Foreground="{StaticResource InkDarkBrush}"
                                               LineHeight="84"
                                               TextOptions.TextFormattingMode="Ideal"/>
                                    <TextBlock Text=":"
                                               FontFamily="{StaticResource PixelMonoFont}"
                                               FontWeight="Bold" FontSize="64"
                                               Foreground="{StaticResource AccentDeepBrush}"
                                               Margin="2,8,2,0"/>
                                    <TextBlock x:Name="TimerSec" Text="00"
                                               FontFamily="{StaticResource PixelMonoFont}"
                                               FontWeight="Bold" FontSize="84"
                                               Foreground="{StaticResource InkDarkBrush}"
                                               LineHeight="84"
                                               TextOptions.TextFormattingMode="Ideal"/>
                                    <TextBlock x:Name="TimerCs" Text=".00"
                                               FontFamily="{StaticResource PixelMonoFont}"
                                               FontWeight="Bold" FontSize="32"
                                               Foreground="{StaticResource InkSoftBrush}"
                                               VerticalAlignment="Bottom"
                                               Margin="6,0,0,8"/>
                                </StackPanel>

                                <!-- Waveform host -->
                                <Grid Grid.Row="2" Margin="18,8,18,4" VerticalAlignment="Center">
                                    <ItemsControl x:Name="WaveformHost"
                                                  Height="120"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                                    <Rectangle Width="8"
                                                               Height="{Binding Height}"
                                                               Fill="{Binding Fill}"
                                                               VerticalAlignment="Bottom"
                                                               SnapsToDevicePixels="True"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>

                                <!-- Transport buttons -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,18">
                                    <Button x:Name="RecordButton"
                                            Style="{StaticResource PixelButton}"
                                            Background="{StaticResource AccentBrush}"
                                            BorderBrush="{StaticResource AccentDeepBrush}"
                                            MinWidth="240" Height="64"
                                            Click="RecordButton_Click"
                                            Margin="0,0,16,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse x:Name="RecordButtonDot"
                                                     Width="20" Height="20"
                                                     Fill="{StaticResource AccentDeepBrush}"
                                                     Stroke="{StaticResource InkDarkBrush}"
                                                     StrokeThickness="2"
                                                     Margin="0,0,12,0"/>
                                            <TextBlock x:Name="RecordButtonText"
                                                       Text="녹음 시작"
                                                       FontSize="20"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="StopButton"
                                            Style="{StaticResource PixelButton}"
                                            Background="{StaticResource PaperBrush}"
                                            BorderBrush="{StaticResource CreamDeepBrush}"
                                            MinWidth="160" Height="64"
                                            IsEnabled="False"
                                            Click="StopButton_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="18" Height="18"
                                                    Background="{StaticResource InkSoftBrush}"
                                                    BorderBrush="{StaticResource InkDarkBrush}"
                                                    BorderThickness="2"
                                                    Margin="0,0,12,0"/>
                                            <TextBlock Text="정지" FontSize="20" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </ContentControl>

                        <!-- ====================================================
                             RIGHT COLUMN — settings + mascot
                             ==================================================== -->
                        <Grid Grid.Row="0" Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="200"/>
                            </Grid.RowDefinitions>

                            <!-- Settings panel -->
                            <ContentControl Grid.Row="0" Style="{StaticResource PixelPanel}">
                                <StackPanel Margin="16">
                                    <TextBlock Text="⚙  녹음 설정"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource InkDarkBrush}"
                                               Margin="0,0,0,12"/>

                                    <TextBlock Text="🎤  입력 장치"
                                               FontSize="12"
                                               Foreground="{StaticResource InkSoftBrush}"
                                               Margin="0,0,0,6"/>
                                    <ComboBox x:Name="DeviceCombo"
                                              Style="{StaticResource PixelComboBox}"
                                              DisplayMemberPath="FriendlyName"
                                              Margin="0,0,0,12"/>

                                    <TextBlock Text="🔊  출력 포맷"
                                               FontSize="12"
                                               Foreground="{StaticResource InkSoftBrush}"
                                               Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <RadioButton Grid.Column="0"
                                                     x:Name="WavToggle"
                                                     Style="{StaticResource FormatToggle}"
                                                     Content="WAV"
                                                     IsChecked="True"
                                                     GroupName="Format"
                                                     Checked="Format_Checked"/>
                                        <RadioButton Grid.Column="1"
                                                     x:Name="Mp3Toggle"
                                                     Style="{StaticResource FormatToggle}"
                                                     Content="MP3"
                                                     GroupName="Format"
                                                     Checked="Format_Checked"
                                                     Margin="-2,0,0,0"/>
                                    </Grid>

                                    <TextBlock Text="입력 레벨"
                                               FontSize="12"
                                               Foreground="{StaticResource InkSoftBrush}"
                                               Margin="0,0,0,6"/>
                                    <Border Background="{StaticResource CreamBrush}"
                                            BorderBrush="{StaticResource InkDarkBrush}"
                                            BorderThickness="2"
                                            Padding="3"
                                            SnapsToDevicePixels="True">
                                        <ItemsControl x:Name="LevelMeter" Height="14">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="1"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Rectangle Fill="{Binding Fill}" Margin="1,0" SnapsToDevicePixels="True"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <TextBlock Text="저장 폴더"
                                               FontSize="12"
                                               Foreground="{StaticResource InkSoftBrush}"
                                               Margin="0,12,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Background="{StaticResource PaperBrush}"
                                                BorderBrush="{StaticResource InkDarkBrush}"
                                                BorderThickness="2"
                                                Padding="10,6"
                                                Margin="0,0,6,0"
                                                SnapsToDevicePixels="True">
                                            <TextBlock x:Name="FolderText"
                                                       Text="..."
                                                       FontSize="12"
                                                       Foreground="{StaticResource InkDarkBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource PixelButton}"
                                                Background="{StaticResource MintBrush}"
                                                BorderBrush="{StaticResource MintDeepBrush}"
                                                Height="34"
                                                Padding="14,0"
                                                FontSize="13"
                                                Content="변경"
                                                Click="ChangeFolder_Click"/>
                                    </Grid>
                                </StackPanel>
                            </ContentControl>

                            <!-- Mascot card -->
                            <ContentControl Grid.Row="2" Style="{StaticResource PixelPanel}"
                                            Background="{StaticResource AccentSoftBrush}">
                                <Grid Margin="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="레코 (Recco)"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource InkDarkBrush}"
                                                   HorizontalAlignment="Left"/>
                                        <TextBlock Text="♥  ★"
                                                   FontSize="14"
                                                   Foreground="{StaticResource AccentDeepBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Grid.Row="1" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Mascot canvas (filled at runtime) -->
                                        <Canvas Grid.Column="0"
                                                x:Name="MascotCanvas"
                                                Width="96" Height="112"
                                                Margin="0,0,12,0"
                                                SnapsToDevicePixels="True"
                                                UseLayoutRounding="True"/>
                                        <!-- speech bubble -->
                                        <Border Grid.Column="1"
                                                Background="{StaticResource PaperBrush}"
                                                BorderBrush="{StaticResource InkDarkBrush}"
                                                BorderThickness="2"
                                                Padding="10,8"
                                                VerticalAlignment="Center"
                                                SnapsToDevicePixels="True">
                                            <TextBlock x:Name="MascotSpeech"
                                                       Text="안녕! 오늘은&#x0a;뭘 녹음할까?"
                                                       FontSize="13"
                                                       Foreground="{StaticResource InkDarkBrush}"
                                                       TextWrapping="Wrap"
                                                       LineHeight="18"/>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </ContentControl>
                        </Grid>

                        <!-- ====================================================
                             BOTTOM — recordings library
                             ==================================================== -->
                        <ContentControl Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                        Style="{StaticResource PixelPanel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- header -->
                                <Border Grid.Row="0"
                                        Background="{StaticResource CreamBrush}"
                                        BorderBrush="{StaticResource InkDarkBrush}"
                                        BorderThickness="0,0,0,3"
                                        Padding="16,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="📁"
                                                   FontSize="18"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="내 녹음 보관함"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource InkDarkBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   x:Name="RecordingCountText"
                                                   Text=" · 0개"
                                                   FontSize="13"
                                                   Foreground="{StaticResource InkSoftBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4"
                                                   x:Name="LibraryFolderHint"
                                                   Text=""
                                                   FontSize="11"
                                                   Foreground="{StaticResource InkSoftBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>

                                <!-- list -->
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="12">
                                    <ItemsControl x:Name="RecordingsList">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="2"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource PaperBrush}"
                                                        BorderBrush="{StaticResource InkDarkBrush}"
                                                        BorderThickness="2"
                                                        Padding="10"
                                                        Margin="6"
                                                        SnapsToDevicePixels="True">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- pixel cassette icon -->
                                                        <Border Grid.Column="0"
                                                                Width="48" Height="32"
                                                                Background="{Binding TapeColor}"
                                                                BorderBrush="{StaticResource InkDarkBrush}"
                                                                BorderThickness="2"
                                                                Margin="0,0,12,0"
                                                                SnapsToDevicePixels="True">
                                                            <Grid>
                                                                <Border Background="{StaticResource PaperBrush}"
                                                                        Width="36" Height="14"
                                                                        VerticalAlignment="Center"
                                                                        SnapsToDevicePixels="True"/>
                                                                <StackPanel Orientation="Horizontal"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center">
                                                                    <Ellipse Width="6" Height="6"
                                                                             Fill="{StaticResource InkDarkBrush}"
                                                                             Margin="0,0,8,0"/>
                                                                    <Ellipse Width="6" Height="6"
                                                                             Fill="{StaticResource InkDarkBrush}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="14"
                                                                       FontWeight="Bold"
                                                                       Foreground="{StaticResource InkDarkBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Meta}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource InkSoftBrush}"
                                                                       Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Style="{StaticResource PixelIconButton}"
                                                                Background="{StaticResource AccentBrush}"
                                                                BorderBrush="{StaticResource AccentDeepBrush}"
                                                                Tag="{Binding Path}"
                                                                Click="PlayRecording_Click"
                                                                Margin="6,0">
                                                            <Path Data="M 0 0 L 8 6 L 0 12 Z"
                                                                  Fill="{StaticResource InkDarkBrush}"
                                                                  Width="8" Height="12"
                                                                  Stretch="Uniform"/>
                                                        </Button>
                                                        <Button Grid.Column="3"
                                                                Style="{StaticResource PixelIconButton}"
                                                                Tag="{Binding Path}"
                                                                Click="DeleteRecording_Click">
                                                            <TextBlock Text="✕"
                                                                       FontSize="14"
                                                                       FontWeight="Bold"
                                                                       Foreground="{StaticResource InkSoftBrush}"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Empty state -->
                                <TextBlock Grid.Row="1"
                                           x:Name="EmptyStateText"
                                           Text="아직 녹음이 없어요. 위 버튼을 눌러 시작!"
                                           FontSize="13"
                                           Foreground="{StaticResource InkSoftBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Visible"/>
                            </Grid>
                        </ContentControl>

                        <!-- corner sparkles -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="★"
                                   FontSize="16"
                                   Foreground="{StaticResource GoldDeepBrush}"
                                   HorizontalAlignment="Left" VerticalAlignment="Top"
                                   Margin="-6,-6,0,0"
                                   Opacity="0.7"
                                   IsHitTestVisible="False"/>
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="♥"
                                   FontSize="16"
                                   Foreground="{StaticResource AccentDeepBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Top"
                                   Margin="0,-6,-6,0"
                                   Opacity="0.7"
                                   IsHitTestVisible="False"/>
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="♪"
                                   FontSize="16"
                                   Foreground="{StaticResource LilacDeepBrush}"
                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                   Margin="-6,0,0,-6"
                                   Opacity="0.7"
                                   IsHitTestVisible="False"/>

                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
